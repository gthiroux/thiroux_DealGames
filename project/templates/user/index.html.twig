{% extends 'base.html.twig' %}

{% block title %}Liste Profil
{% endblock %}
{% block stylesheets %}
	{{parent()}}
	<link rel="stylesheet" href="{{asset('style/pages/global.css')}}">
{% endblock %}
{% block content %}
	<div class="content">
		<h1>Liste des profils</h1>
		<a href="{{ path('app_user_new') }}" class="btn">Créer un nouveau utilisateur</a>

		<table class="table">
			<thead>
				<tr>
					<th>Nom de famille</th>
					<th>Prénom</th>
					<th>Email</th>
					<th>Roles</th>
					<th>Date création de compte</th>
					<th>Verifié ?</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				{% for user in users %}
					<tr>
						<td>{{ user.lastname }}</td>
						<td>{{ user.firstname }}</td>
						<td>{{ user.email }}</td>
						<td>{{ user.roles ? user.roles|json_encode : '' }}</td>
						<td>{{ user.registeredDate ? user.registeredDate|date('d/m/Y') : '' }}</td>
						<td>{{ user.isVerified ? 'Oui' : 'Non' }}</td>
						<td>
							<a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn">Voir les détails</a>
							<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn">Modifier</a>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="9">Pas d'utilisateurs
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>

{% endblock %}
