{% extends 'base.html.twig' %}

{% block title %}Acceuil
{% endblock %}

{% block body %}
	<h1>Liste des annonces</h1>

	{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_USER') %}
		<a href="{{ path('app_ad_new') }}">
			Créer une nouvelle annonce</a>

	{% endif %}

	<table class="table">
		<thead>
			<tr>
				<th>Title</th>
				<th>Description</th>
				<th>Authore</th>
				{# <th>ImageName</th>#}
			{#<th>ImageSize</th>#}
				{#<th>UpdatedAt</th> #}

			</tr>
		</thead>
	</tr>
</thead>
<tbody>
	{% for ad in ads %}
		<tr>
			<td>{{ ad.title }}</td>
			<td>{{ ad.description }}</td>
			<td>{{ [ad.user.lastname ,ad.user.firstname] | join(" ")}}</td>
			{# <td>{{ ad.imageName }}</td> #}
			{# <td>{{ ad.imageSize }}</td> #}
			{# <td>{{ ad.updatedAt ? ad.updatedAt|date('Y-m-d H:i:s') : '' }}</td> #}
				<td>
			{{ ad.publicatedDate ? ad.publicatedDate|date('Y-m-d') : '' }}
			</td>
				<td>
					<a href="{{ path('app_ad_show', {'id': ad.id}) }}"> show</a>
			</td>
			{% if is_granted('ROLE_ADMIN') or (app.user and ad.user == app.user) %}

				<td>
					<a href="{{ path('app_ad_edit', {'id': ad.id}) }}">edit</a>
				</td>
			{% endif %}
		</tr>
	{% else %}
		<tr>
			<td colspan="8">no records found</td>
		</tr>
	{% endfor %}
</tbody></tbody></table><a href="{{ path('app_ad_new') }}">Create new</a>{% endblock %}
