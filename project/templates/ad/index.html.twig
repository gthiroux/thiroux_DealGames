{% extends 'base.html.twig' %}

{% block title %}Acceuil
{% endblock %}
{% block stylesheets %}
	{{parent()}}
	<link rel="stylesheet" href="{{asset('style/pages/global.css')}}">
{% endblock %}
{% block content %}
	<div class="content">
		<h1>Liste des annonces</h1>

		{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_USER') %}
			<a href="{{ path('app_ad_new') }}">
				Créer une nouvelle annonce</a>

		{% endif %}

		<table class="table">
			<thead>
				<tr>
					<th></th>
					<th>Title</th>
					<th>Description</th>
					<th>Auteur</th>
					<th>Date de publication</th>
					<th></th>
					<th></th>

				</tr>
			</thead>

			<tbody>
				{% for ad in ads %}
					<tr>
						<td>
							{% if ad.imageName %}
								<img src="{{ vich_uploader_asset(ad, 'imageFile') }}" alt="{{ ad.title }}" style="width: 100px; height: auto;">
							{% else %}
								<span>Aucune image</span>
							{% endif %}
						</td>
						<td>{{ ad.title }}</td>
						<td>{{ ad.description }}</td>
						<td>{{ [ad.user.firstname , ad.user.lastname] | join(" ")}}</td>
						<td>
							{{ ad.publicatedDate ? ad.publicatedDate|date('d/m/Y') : '' }}
						</td>
						<td>
							<a href="{{ path('app_ad_show', {'id': ad.id}) }}">
								Voir les détails</a>
						</td>
						{% if is_granted('ROLE_ADMIN') or (app.user and ad.user == app.user) %}

							<td>
								<a href="{{ path('app_ad_edit', {'id': ad.id}) }}">Modifier l'annonce</a>
							</td>
						{% endif %}
					</tr>
				{% else %}
					<tr>
						<td colspan="8">Pas encore d'annonce</td>
					</tr>
				{% endfor %}
			</tbody>
		</tbody>
	</table>
</div>{% endblock %}
