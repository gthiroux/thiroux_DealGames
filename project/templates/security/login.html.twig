{% extends 'base.html.twig' %}

{% block title %}Connexion
{% endblock %}
{% block stylesheets %}
	{{parent()}}
	<link rel="stylesheet" href="{{asset('style/pages/global.css')}}">
{% endblock %}
{% block content %}
	<div class="content">
		<form method="post">
			{% if error %}
				<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
			{% endif %}

			{% if app.user %}
				<div class="mb-3">
					Vous êtes connecté avec l'adresse mail :
					{{ app.user.userIdentifier }},
					<a href="{{ logout_path() }}">Déconnexion</a>
				</div>
			{% endif %}

			<h1 class="h3 mb-3 font-weight-normal">Connectez-vous</h1>
			<label for="username">Email</label>
			<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
			<label for="password">Mot de passe</label>
			<input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
			<input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
			<div class="form-check mb-3">
				<input type="checkbox" name="_remember_me" id="_remember_me">
				<label for="_remember_me">Se souvenir de moi</label>
			</div>

			<button class="btn btn-lg btn-primary" type="submit">
				Connexion
			</button>

		</form>
		<p>
			<a href="{{ path('app_register') }}" class="btn_list">Me créer un compte</a>
		</p>
		<p>
			<a href="{{ path('forgotten_password') }}">Mot de passe oublié ?</a>
		</p>
	</div>
{% endblock %}
